// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // App/runtime queries: use Supabase pooler (6543) in production if you want.
  // Migrations always use directUrl — PgBouncer poolers often hang or fail on migrate.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  passwordHash String
  isAdmin Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id    Int     @id @default(autoincrement())
  name String
  email String @unique
  company String?
  phone String?
  siteUrl String?  // https://example.com
  /// Set at account signup; portal code remains optional backup login
  passwordHash String?
  pricingTier String // plan id or "pending" before first checkout
  numSites Int @default(1)
  stripeCustomerId String?
  portalCodeHash String? // hashed portal code for customer dashboard login
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
  payments Payment[]
}

model Subscription {
  id    Int     @id @default(autoincrement())
  clientId Int
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String @unique
  status String // "active" | "canceled" | "past_due" | "unpaid"
  currentPeriodStart DateTime
  currentPeriodEnd DateTime
  nextBillingDate DateTime?
  amountMonthly Int // in cents

  // Cancellation fields
  canceledAt DateTime?
  codeDeliveryMethod String? // "github" | "thumbdrive"
  codeDeliveryStatus String? // "pending" | "sent" | "delivered"
  codeDeliveryDate DateTime?
  cancellationReason String?
  cancellationNotes String?
  githubRepoUrl String?  // Link to their code repo

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id    Int     @id @default(autoincrement())
  clientId Int
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  stripePaymentId String @unique
  amount Int // in cents
  paymentType String // "one_time" | "subscription"
  status String // "succeeded" | "failed" | "pending"
  paidAt DateTime?
  invoiceUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactSubmission {
  id    Int     @id @default(autoincrement())
  name String
  email String
  message String
  projectType String?
  createdAt DateTime @default(now())
}

/// Admin-created codes; backed by Stripe Coupon + Promotion Code
model PromoCode {
  id    Int     @id @default(autoincrement())
  /// Uppercase normalized code customers type at checkout (e.g. LAUNCH25)
  code String @unique
  label String?
  stripeCouponId String
  stripePromotionCodeId String @unique
  discountType String // "percent" | "amount"
  percentOff Int?
  amountOffCents Int?
  maxRedemptions Int?
  timesRedeemed Int @default(0)
  expiresAt DateTime?
  active Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  redemptionLogs PromoRedemptionLog[]
}

/// Prevents double-counting promo redemptions on webhook retries
model PromoRedemptionLog {
  checkoutSessionId String @id
  promoCodeId Int
  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
